# --- Claude / Anthropic ---
# Required for AI plan generation (Claude Agent SDK reads this).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- App security ---
# Secret used to sign auth (JWT) tokens. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=change-me-to-a-long-random-string

# How long an auth token stays valid (minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database / storage ---
# SQLite file location (relative to backend/).
DATABASE_URL=sqlite:///./data/coach.sqlite3

# Where per-user Garmin OAuth tokens are stored.
GARMIN_TOKENS_DIR=./data/garmin_tokens

# --- AI defaults (can be changed per-user in Settings) ---
DEFAULT_AI_MODEL=claude-sonnet-4-5
DEFAULT_REASONING_EFFORT=medium

# --- Sync ---
# Hour of day (0-23, local time) to run the automatic daily Garmin sync.
DAILY_SYNC_HOUR=5
# How many days back to pull on a routine sync.
SYNC_LOOKBACK_DAYS=14
